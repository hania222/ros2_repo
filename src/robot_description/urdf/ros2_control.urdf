<?xml version="1.0" encoding="utf-8"?>
<robot name="Wheeled_Base">

  <!-- ═══════════════════════════════════════════════════
       ros2_control hardware interface
       ═══════════════════════════════════════════════════ -->
  <ros2_control name="WheelBase_ros2_control" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="left_wheel">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_swivel">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_rolling">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_swiveling">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_rolling">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ═══════════════════════════════════════════════════
       Gazebo plugins
       ═══════════════════════════════════════════════════ -->
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>__CONTROLLERS_YAML__</parameters>
      <ros>
        <namespace>/</namespace>
      </ros>
    </plugin>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════
       Wheel friction
       ═══════════════════════════════════════════════════ -->
  <gazebo reference="LEFT_WHEEL">
    <mu1>0.8</mu1><mu2>0.8</mu2>
    <kp>1000000.0</kp><kd>1.0</kd>
    <minDepth>0.001</minDepth><maxVel>0.1</maxVel>
  </gazebo>
  <gazebo reference="RIGHT_WHEEL">
    <mu1>0.8</mu1><mu2>0.8</mu2>
    <kp>1000000.0</kp><kd>1.0</kd>
    <minDepth>0.001</minDepth><maxVel>0.1</maxVel>
  </gazebo>
  <gazebo reference="FRONT_ROLLING">
    <mu1>0.01</mu1><mu2>0.01</mu2>
  </gazebo>
  <gazebo reference="REAR_ROLLING">
    <mu1>0.01</mu1><mu2>0.01</mu2>
  </gazebo>

  <!-- ═══════════════════════════════════════════════════
       LiDAR physical link + joint
       (defined here so _merge_urdfs inserts them into the
        base URDF's <robot> block alongside CHASSIS)
       ═══════════════════════════════════════════════════ -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.04"/></geometry>
      <material name="lidar_black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.170"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="CHASSIS"/>
    <child  link="lidar_link"/>
    <origin xyz="-0.32 0.0 0.055" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════
       Gazebo sensor block for the LiDAR

       CRITICAL FIXES vs previous version:
         1. <gz_frame_id> stamps every LaserScan with "lidar_link"
            so ros_gz_bridge forwards the correct frame_id to ROS2
         2. <visualize> is INSIDE <sensor> (Gazebo ignores it outside)
         3. <pose relative_to="lidar_link"> anchors the ray origin
            explicitly — avoids Gazebo silently using world origin
         4. sensor type uses the fully-qualified string recognised by
            Gazebo Harmonic/Ionic: "gpu_lidar"  (NOT "ray")
       ═══════════════════════════════════════════════════ -->
  <gazebo reference="lidar_link">
    <sensor name="rplidar_a1" type="gpu_lidar">
      <pose relative_to="lidar_link">0 0 0 0 0 0</pose>
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <update_rate>5.5</update_rate>
      <visualize>true</visualize>
      <always_on>true</always_on>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle> 3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

</robot>