    </link>
  </model>

  <!-- Row C — x = 2 -->
  <model name="shelf_C1">
    <static>true</static>
    <pose>2 -6 0.75 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>0.15 2.5 1.5</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.15 2.5 1.5</size></box></geometry>
        <material><ambient>0.45 0.28 0.08 1</ambient><diffuse>0.55 0.35 0.12 1</diffuse></material>
      </visual>
    </link>
  </model>

  <model name="shelf_C2">
    <static>true</static>
    <pose>2 0 0.75 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>0.15 2.5 1.5</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.15 2.5 1.5</size></box></geometry>
        <material><ambient>0.45 0.28 0.08 1</ambient><diffuse>0.55 0.35 0.12 1</diffuse></material>
