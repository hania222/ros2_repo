  <!-- ===== HORIZONTAL SHELF BOARDS (visual detail on shelf units) ===== -->
  <!-- Shelf A1 boards at 3 heights -->
  <model name="board_A1_low">
    <static>true</static>
    <pose>-6 -6 0.45 0 0 0</pose>
    <link name="link">
      <collision name="collision">
        <geometry><box><size>0.4 2.5 0.04</size></box></geometry>
      </collision>
      <visual name="visual">
        <geometry><box><size>0.4 2.5 0.04</size></box></geometry>
        <material><ambient>0.38 0.22 0.06 1</ambient><diffuse>0.42 0.26 0.08 1</diffuse></material>
